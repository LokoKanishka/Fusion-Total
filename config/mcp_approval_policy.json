{
  "required_fields": {
    "write": [
      "approved_by",
      "approval_token",
      "approval_ts",
      "approval_scope"
    ],
    "sensitive": [
      "approved_by",
      "approval_token",
      "approval_ts",
      "approval_scope",
      "approval_justification",
      "approval_change_ticket"
    ]
  },
  "token_pattern": "^[A-Za-z0-9._:-]{8,128}$",
  "ticket_pattern": "^(CHG|INC|TASK)-[A-Za-z0-9_-]{3,64}$",
  "max_age_seconds": {
    "write": 1800,
    "sensitive": 900
  },
  "require_scope_match": true,
  "hmac": {
    "enabled": true,
    "algorithm": "sha256",
    "secret_env_var": "MCP_APPROVAL_HMAC_SECRET",
    "field": "approval_sig",
    "require_for_levels": [
      "write",
      "sensitive"
    ]
  }
}
